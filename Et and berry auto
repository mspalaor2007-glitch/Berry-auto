-- ================= PARTE 4: MOTOR DE VOO UNIVERSAL (IGNORA TRAVA DE MORFO) ================= --

local bodyVelocity = nil
local bodyGyro = nil

RunService.Heartbeat:Connect(function()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    local camera = Workspace.CurrentCamera

    if _G.VooLivreAtivo and rootPart and humanoid and camera then
        ativarNoclipLocal(true)
        
        humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
        humanoid.AutoRotate = false
        humanoid.PlatformStand = true
        
        if flyStateEvent then flyStateEvent:FireServer(true) end

        if not bodyVelocity or bodyVelocity.Parent ~= rootPart then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.Name = "MorphFlyVelocity"
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.P = 1250
            bodyVelocity.Parent = rootPart
        end
        
        if not bodyGyro or bodyGyro.Parent ~= rootPart then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.Name = "MorphFlyGyro"
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.D = 500
            bodyGyro.P = 3000
            bodyGyro.Parent = rootPart
        end

        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

        local direcao = humanoid.MoveDirection
        if direcao.Magnitude > 0 then
            local vetorCamera = camera.CFrame.LookVector
            local direcaoVoo = Vector3.new(direcao.X, vetorCamera.Y, direcao.Z)
            bodyVelocity.Velocity = direcaoVoo.Unit * _G.VelocidadeVoo
        else
            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
        
        local lookVectHorizontal = camera.CFrame.LookVector * Vector3.new(1, 0, 1)
        if lookVectHorizontal.Magnitude > 0.01 then
            bodyGyro.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + lookVectHorizontal)
        end
    else
        if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        
        local precisaDeVooAinda = _G.PerseguirPlayer or _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry or _G.AutoFarmMegaBerry
        
        if not precisaDeVooAinda then
            if flyStateEvent then flyStateEvent:FireServer(false) end
            if humanoid and humanoid.PlatformStand then
                humanoid.PlatformStand = false
                ativarNoclipLocal(false)
                
                humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.GettingUp, true)
                humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
                humanoid.AutoRotate = true
            end
        end
    end
end)

