-- Noclip local para evitar colisões com o mapa
local noclipConnection = nil
local function ativarNoclipLocal(status)
    if status then
        if not noclipConnection then
            noclipConnection = RunService.Stepped:Connect(function()
                local character = player.Character
                if character then
                    for _, part in pairs(character:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
    end
end

-- ================= PARTE 2: MOTORES DE MOVIMENTAÇÃO (CFRAME + NOCLIP CONTÍNUO) ================= --

local function voarAteAlvoSeparado(alvo, velHorizontal, velVertical)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    if not rootPart or not humanoid or not alvo or not alvo.Parent then return end

    -- Liga o noclip local quando o farm começa
    ativarNoclipLocal(true)
    humanoid.PlatformStand = true 

    local alturaAlvo = alvo.Position.Y + _G.AlturaHover - 5
    if _G.BypassWalls then
        alturaAlvo = _G.AlturaSeguraCeu
    end

    while _G.AutoFarmMegaBerry or _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry do
        if not alvo or not alvo.Parent or not rootPart then break end

        -- 🌟 NOCLIP CONTÍNUO: Desativa a colisão do corpo a cada frame para não travar em nada
        if character then
            for _, part in pairs(character:GetChildren()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end

        -- Força a física do jogo a zerar para o voo nativo não atrapalhar
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

        -- 1️⃣ CFrame Vertical (Subida e Descida)
        local alturaAtual = rootPart.Position.Y
        local diferencaY = alturaAlvo - alturaAtual
        
        if math.abs(diferencaY) > 0.3 then
            local direcaoY = diferencaY > 0 and 1 or -1
            local passoY = direcaoY * velVertical * 0.02 
            if math.abs(passoY) > math.abs(diferencaY) then
                alturaAtual = alturaAlvo
            else
                alturaAtual = alturaAtual + passoY
            end
        end

        -- 2️⃣ CFrame Horizontal Puro (Frente, Trás, Lados sem Física)
        local destinoHorizontal = Vector3.new(alvo.Position.X, alturaAtual, alvo.Position.Z)
        local direcaoHorizontal = (destinoHorizontal - Vector3.new(rootPart.Position.X, alturaAtual, rootPart.Position.Z))
        local distHorizontal = direcaoHorizontal.Magnitude

        -- Condição de parada (chegou perto da berry)
        if distHorizontal < 1.5 and math.abs(rootPart.Position.Y - alturaAlvo) < 1.5 then 
            break 
        end

        local novaPosicao = rootPart.Position
        if distHorizontal > 0.1 then
            local direcaoUnit = direcaoHorizontal.Unit
            local passoXZ = direcaoUnit * velHorizontal * 0.02
            
            if passoXZ.Magnitude > distHorizontal then
                novaPosicao = destinoHorizontal
            else
                novaPosicao = rootPart.Position + passoXZ
            end
        end

        -- Aplica a posição calculada e faz olhar para a Berry
        if distHorizontal > 0.5 then
            local olharSeguro = Vector3.new(alvo.Position.X, alturaAtual, alvo.Position.Z)
            rootPart.CFrame = CFrame.lookAt(Vector3.new(novaPosicao.X, alturaAtual, novaPosicao.Z), olharSeguro)
        else
            rootPart.CFrame = CFrame.new(Vector3.new(novaPosicao.X, alturaAtual, novaPosicao.Z), rootPart.CFrame.LookVector)
        end

        -- 🚀 Sincroniza com a taxa de atualização do jogo (Fluidez Máxima)
        RunService.Heartbeat:Wait()
    end

    if rootPart then rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
    if humanoid then humanoid.PlatformStand = false end
    
    -- Desliga o noclip quando o farm termina
    ativarNoclipLocal(false)
end

-- Função de busca de alvos próximos (Atualizada para checar os Atributos do Dex Explorer)
local function pegarAlvoMaisProximo(nomePasta, nomeItem, corObrigatoria, apenasMega)
    local pasta = Workspace:FindFirstChild(nomePasta)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")

    if pasta and rootPart then
        local alvo = nil
        local menorDistancia = math.huge

        for _, item in pairs(pasta:GetChildren()) do
            if item.Name == nomeItem then
                local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                
                if targetPart then
                    local colValida = true
                    
                    -- Filtro para Golden Berry (Pela cor laranja "Deep orange")
                    if corObrigatoria and targetPart.BrickColor.Name ~= "Deep orange" then
                        colValida = false
                    end

                    -- Filtro para Mega Berry (Lendo o atributo "BerryType" = "mega")
                    if apenasMega and item:GetAttribute("BerryType") ~= "mega" then
                        colValida = false
                    end

                    if colValida then
                        local dist = (rootPart.Position - targetPart.Position).Magnitude
                        if dist < menorDistancia then
                            menorDistancia = dist
                            alvo = targetPart
                        end
                    end
                end
            end
        end
        return alvo
    end
    return nil
end

-- Loop principal do Fly Farm (Organizado por prioridades de ativação)
task.spawn(function()
    while true do
        local alvoAtual = nil
        
        if _G.AutoFarmMegaBerry then
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry", false, true) -- Busca as frutinhas Mega por Atributo
        elseif _G.AutoFarmGoldenBerry then
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry", true, false) -- Busca as Goldens por cor
        elseif _G.AutoFarmAlien then
            alvoAtual = pegarAlvoMaisProximo("Aliens", "Alien", false, false)
        elseif _G.AutoFarmBerry then
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry", false, false) -- Busca as comuns
        end

        if alvoAtual then
            voarAteAlvoSeparado(alvoAtual, _G.VelocidadeFarm, _G.VelocidadeSubidaCFrame)
        end
        
        task.wait(0.1)
    end
end)

-- ================= PARTE 3: VOO MANUAL, PERSEGUIÇÃO E INTERFACE UI ================= --

local bodyVelocity = nil
local bodyGyro = nil

RunService.RenderStepped:Connect(function()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    local camera = Workspace.CurrentCamera

    if _G.VooLivreAtivo and rootPart and humanoid and camera then
        ativarNoclipLocal(true)
        humanoid.PlatformStand = true

        if not bodyVelocity or bodyVelocity.Parent ~= rootPart then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Parent = rootPart
        end
        
        if not bodyGyro or bodyGyro.Parent ~= rootPart then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.D = 100
            bodyGyro.P = 10000
            bodyGyro.Parent = rootPart
        end

        bodyGyro.CFrame = camera.CFrame
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

        local direcao = humanoid.MoveDirection
        if direcao.Magnitude > 0 then
            local vetorCamera = camera.CFrame.LookVector
            local direcaoVoo = Vector3.new(direcao.X, vetorCamera.Y, direcao.Z)
            bodyVelocity.Velocity = direcaoVoo.Unit * _G.VelocidadeVoo
        else
            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    else
        if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        
        if humanoid and humanoid.PlatformStand and not _G.PerseguirPlayer and not _G.AutoFarmGoldenBerry and not _G.AutoFarmAlien and not _G.AutoFarmBerry and not _G.AutoFarmMegaBerry then
            humanoid.PlatformStand = false
            ativarNoclipLocal(false)
        end
    end
end)

local function obterListaPlayers()
    local lista = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then table.insert(lista, p.Name) end
    end
    return lista
end

-- Motor de Perseguição Atualizado (Muda de Alvo APENAS se o Player Morrer)
task.spawn(function()
    while true do
        if _G.PerseguirPlayer then
            local tPlayer = nil

            -- 1️⃣ Definição do Alvo (Modo Aleatório ou Alvo Fixo)
            if _G.ModoAleatorioPlayers then
                -- Verifica se o alvo atual ainda existe, tem corpo e está VIVO
                local alvoAtualValido = Players:FindFirstChild(_G.PlayerAlvo)
                local estaVivo = false
                
                if alvoAtualValido and alvoAtualValido.Character and alvoAtualValido.Character:FindFirstChild("HumanoidRootPart") then
                    local hum = alvoAtualValido.Character:FindFirstChildWhichIsA("Humanoid")
                    if hum and hum.Health > 0 then
                        estaVivo = true
                    end
                end

                -- SE NÃO ESTIVER VIVO (OU SE NÃO TIVER ALVO): Escolhe um novo player vivo aleatório
                if not estaVivo then
                    local todosPlayersVivos = {}
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildWhichIsA("Humanoid") and p.Character:FindFirstChildWhichIsA("Humanoid").Health > 0 then
                            table.insert(todosPlayersVivos, p)
                        end
                    end
                    
                    if #todosPlayersVivos > 0 then
                        local escolhido = todosPlayersVivos[math.random(1, #todosPlayersVivos)]
                        _G.PlayerAlvo = escolhido.Name
                        tPlayer = escolhido
                    else
                        tPlayer = nil
                    end
                else
                    -- Se o atual continua vivo, mantém o foco nele rigidamente
                    tPlayer = alvoAtualValido
                end
            else
                -- Modo de Alvo Fixo Manual
                tPlayer = Players:FindFirstChild(_G.PlayerAlvo)
            end

            -- 2️⃣ Execução da Movimentação Estilo CFrame Farm (Fica colado enquanto estiver vivo)
            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")

            if tPlayer and tPlayer.Character and rootPart and humanoid then
                local tRoot = tPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tHumanoid = tPlayer.Character:FindFirstChildWhichIsA("Humanoid")

                if tRoot and tHumanoid and tHumanoid.Health > 0 then
                    humanoid.PlatformStand = true
                    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

                    local posicaoCostas = (tRoot.CFrame * CFrame.new(0, 0, _G.DistanciaCostas)).Position
                    local direcaoIr = (posicaoCostas - rootPart.Position)
                    local distanciaAtual = direcaoIr.Magnitude

                    if distanciaAtual > 0.5 then
                        local direcaoUnit = direcaoIr.Unit
                        local passo = direcaoUnit * _G.VelocidadePerseguicao * 0.02
                        
                        local novaPosicao = rootPart.Position + passo
                        if passo.Magnitude > distanciaAtual then
                            novaPosicao = posicaoCostas
                        end

                        rootPart.CFrame = CFrame.lookAt(novaPosicao, Vector3.new(tRoot.Position.X, novaPosicao.Y, tRoot.Position.Z))
                    else
                        -- Segue a rotação exata e gruda na posição enquanto ele se move vivo
                        rootPart.CFrame = CFrame.new(posicaoCostas, tRoot.Position)
                    end
                else
                    -- Se o alvo morreu/resgatou neste frame, reseta o alvo para o próximo ciclo escolher outro
                    if _G.ModoAleatorioPlayers then _G.PlayerAlvo = "" end
                end
            else
                -- Se o player saiu do jogo ou sumiu do Workspace
                if _G.ModoAleatorioPlayers then _G.PlayerAlvo = "" end
            end
        else
            local character = player.Character
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.PlatformStand and not _G.VooLivreAtivo and not _G.AutoFarmBerry and not _G.AutoFarmAlien and not _G.AutoFarmGoldenBerry and not _G.AutoFarmMegaBerry then
                humanoid.PlatformStand = false
            end
        end
        
        RunService.Heartbeat:Wait()
    end
end)

