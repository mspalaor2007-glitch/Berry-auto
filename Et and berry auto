-- ================= PARTE 3: ENGINE DE DESLOCAMENTO EM CFRAME E LOOP PRINCIPAL DO FARM ================= --

local function moverParaAlvoCFrame(parteAlvo, tipoFarm, deltaTime)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    if not rootPart or not humanoid or not parteAlvo then return end

    humanoid.PlatformStand = true
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

    local alturaDefinida = _G.AlturaHover
    if tipoFarm == "Mega" or tipoFarm == "Golden" then
        alturaDefinida = 0 
    end

    local posicaoFinal = parteAlvo.Position + Vector3.new(0, alturaDefinida, 0)
    local distanciaXy = Vector3.new(posicaoFinal.X, 0, posicaoFinal.Z) - Vector3.new(rootPart.Position.X, 0, rootPart.Position.Z)
    local distanciaTotal = (posicaoFinal - rootPart.Position).Magnitude

    if _G.BypassWalls and distanciaXy.Magnitude > 15 then
        if rootPart.Position.Y < _G.AlturaSeguraCeu then
            rootPart.CFrame = rootPart.CFrame + Vector3.new(0, _G.VelocidadeSubidaCFrame * deltaTime, 0)
            return
        end
        
        local posicaoCeu = Vector3.new(posicaoFinal.X, _G.AlturaSeguraCeu, posicaoFinal.Z)
        local direcaoCeu = (posicaoCeu - rootPart.Position)
        
        if direcaoCeu.Magnitude > 1 then
            rootPart.CFrame = CFrame.new(rootPart.Position + (direcaoCeu.Unit * _G.VelocidadeFarm * deltaTime), posicaoCeu)
            return
        else
            rootPart.CFrame = CFrame.new(rootPart.Position + (Vector3.new(0, -1, 0) * _G.VelocidadeSubidaCFrame * deltaTime), posicaoFinal)
            return
        end
    end

    if distanciaTotal > 0.5 then
        local direcao = (posicaoFinal - rootPart.Position).Unit
        local passo = direcao * _G.VelocidadeFarm * deltaTime
        
        if passo.Magnitude > distanciaTotal then
            rootPart.CFrame = CFrame.new(posicaoFinal)
        else
            rootPart.CFrame = CFrame.new(rootPart.Position + passo)
        end
    else
        rootPart.CFrame = CFrame.new(posicaoFinal)
    end
end

RunService.Heartbeat:Connect(function(deltaTime)
    local farmAtivo = _G.AutoFarmMegaBerry or _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry
    gerenciarSinalVooFarm(farmAtivo)

    if not farmAtivo then return end

    ativarNoclipLocal(true)
    local alvoAtual = nil
    local tipoAtual = ""

    if _G.AutoFarmMegaBerry then 
        tipoAtual = "Mega"
        alvoAtual = obterItemMaisProximoAvancado("Mega")
    elseif _G.AutoFarmGoldenBerry then 
        tipoAtual = "Golden"
        alvoAtual = obterItemMaisProximoAvancado("Golden")
    elseif _G.AutoFarmAlien then 
        tipoAtual = "Alien"
        alvoAtual = obterItemMaisProximoAvancado("Alien")
    elseif _G.AutoFarmBerry then 
        tipoAtual = "Comum"
        alvoAtual = obterItemMaisProximoAvancado("Comum") 
    end

    if alvoAtual then 
        moverParaAlvoCFrame(alvoAtual, tipoAtual, deltaTime) 
    end
end)

