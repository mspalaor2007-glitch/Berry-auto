-- ================= PARTE 2: NOVO MOTOR DE VALIDAÇÃO E COLETA REFEITO ================= --

local flyStateEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("FlyStateChanged")

local function gerenciarSinalVooFarm(ativo)
    if _G.VooLivreAtivo then return end
    
    if ativo then
        if flyStateEvent then flyStateEvent:FireServer(true) end
    else
        local nenhumFarmAtivo = not _G.AutoFarmMegaBerry and not _G.AutoFarmGoldenBerry and not _G.AutoFarmAlien and not _G.AutoFarmBerry and not _G.PerseguirPlayer
        if nenhumFarmAtivo then
            if flyStateEvent then flyStateEvent:FireServer(false) end
        end
    end
end

-- Buscador avançado de Berries, Moedas e Coletáveis no Workspace
local function obterItemMaisProximoAvancado(tipoFarm)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    local menorDistancia = math.huge
    local itemEscolhido = nil
    
    for _, objeto in pairs(Workspace:GetDescendants()) do
        local valido = false
        local nomeMinusculo = string.lower(objeto.Name)
        
        if tipoFarm == "Mega" then
            if (string.find(nomeMinusculo, "mega") and string.find(nomeMinusculo, "berry")) or string.find(nomeMinusculo, "megaberry") or string.find(nomeMinusculo, "superberry") then
                valido = true
            end
        elseif tipoFarm == "Golden" then
            if string.find(nomeMinusculo, "gold") or string.find(nomeMinusculo, "moeda") or string.find(nomeMinusculo, "coin") or string.find(nomeMinusculo, "ouro") then
                valido = true
            end
        elseif tipoFarm == "Alien" then
            if string.find(nomeMinusculo, "alien") then
                valido = true
            end
        elseif tipoFarm == "Comum" then
            if string.find(nomeMinusculo, "berry") and not string.find(nomeMinusculo, "mega") and not string.find(nomeMinusculo, "golden") and not string.find(nomeMinusculo, "gold") and not string.find(nomeMinusculo, "coin") then
                valido = true
            end
        end

        if valido then
            local parteAlvo = nil
            if objeto:IsA("BasePart") then
                parteAlvo = objeto
            elseif objeto:IsA("Model") and objeto.PrimaryPart then
                parteAlvo = objeto.PrimaryPart
            else
                parteAlvo = objeto:FindFirstChildWhichIsA("BasePart")
            end

            if parteAlvo and parteAlvo.Position then
                local distancia = (rootPart.Position - parteAlvo.Position).Magnitude
                if distancia < menorDistancia then
                    menorDistancia = distancia
                    itemEscolhido = parteAlvo
                end
            end
        end
    end

    return itemEscolhido
end
