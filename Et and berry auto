-- ================= PARTE 5: MOTOR DE PERSEGUIÇÃO E ATIVAÇÃO DO KILL AURA SIMULTÂNEO ================= --

local attackEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("AttackRequest")
local ultimoAtaque = 0
local delayAtaque = 0.1 -- Debounce interno para reduzir flutuações e latência de rede

local function obterListaPlayers()
    local lista = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then table.insert(lista, p.Name) end
    end
    return lista
end

task.spawn(function()
    while true do
        local deltaTime = RunService.Heartbeat:Wait()
        
        if _G.PerseguirPlayer then
            local tPlayer = nil

            if _G.ModoAleatorioPlayers then
                local alvoAtualValido = Players:FindFirstChild(_G.PlayerAlvo)
                local estaVivo = false
                
                if alvoAtualValido and alvoAtualValido.Character and alvoAtualValido.Character:FindFirstChild("HumanoidRootPart") then
                    local hum = alvoAtualValido.Character:FindFirstChildWhichIsA("Humanoid")
                    if hum and hum.Health > 0 then estaVivo = true end
                end

                if not estaVivo then
                    local todosPlayersVivos = {}
                    for _, p in pairs(Players:GetPlayers()) do
                        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChildWhichIsA("Humanoid") and p.Character:FindFirstChildWhichIsA("Humanoid").Health > 0 then
                            table.insert(todosPlayersVivos, p)
                        end
                    end
                    if #todosPlayersVivos > 0 then
                        local escolhido = todosPlayersVivos[math.random(1, #todosPlayersVivos)]
                        _G.PlayerAlvo = escolhido.Name
                        tPlayer = escolhido
                    else
                        tPlayer = nil
                    end
                else
                    tPlayer = alvoAtualValido
                end
            else
                tPlayer = Players:FindFirstChild(_G.PlayerAlvo)
            end

            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")

            if tPlayer and tPlayer.Character and rootPart and humanoid then
                local tRoot = tPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tHumanoid = tPlayer.Character:FindFirstChildWhichIsA("Humanoid")

                if tRoot and tHumanoid and tHumanoid.Health > 0 then
                    ativarNoclipLocal(true)
                    humanoid.PlatformStand = true
                    
                    humanoid:SetStateEnabled(Enum.HumanoidStateType.FallingDown, false)
                    humanoid:SetStateEnabled(Enum.HumanoidStateType.GettingUp, false)
                    humanoid:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
                    humanoid.AutoRotate = false

                    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

                    local posicaoCostas = (tRoot.CFrame * CFrame.new(0, 0, _G.DistanciaCostas)).Position
                    local direcaoIr = (posicaoCostas - rootPart.Position)
                    local distanciaAtual = direcaoIr.Magnitude

                    if distanciaAtual > 0.5 then
                        local direcaoUnit = direcaoIr.Unit
                        local passo = direcaoUnit * _G.VelocidadePerseguicao * deltaTime
                        local novaPosicao = rootPart.Position + passo
                        if passo.Magnitude > distanciaAtual then novaPosicao = posicaoCostas end
                        rootPart.CFrame = CFrame.lookAt(novaPosicao, Vector3.new(tRoot.Position.X, novaPosicao.Y, tRoot.Position.Z))
                    else
                        rootPart.CFrame = CFrame.new(posicaoCostas, tRoot.Position)
                        
                        if _G.KillAuraAtivo and attackEvent and (tick() - ultimoAtaque >= delayAtaque) then
                            ultimoAtaque = tick()
                            attackEvent:FireServer()
                        end
                    end
                else
                    if _G.ModoAleatorioPlayers then _G.PlayerAlvo = "" end
                end
            else
                if _G.ModoAleatorioPlayers then _G.PlayerAlvo = "" end
            end
        else
            local character = player.Character
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.PlatformStand and not _G.VooLivreAtivo and not _G.AutoFarmBerry and not _G.AutoFarmAlien and not _G.AutoFarmGoldenBerry and not _G.AutoFarmMegaBerry then
                humanoid.PlatformStand = false
            end
        end
    end
end)

