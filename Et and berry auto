-- Garante que o boneco não se machuque ou prenda em texturas locais
local noclipConnection = nil
local function ativarNoclipLocal(status)
    if status then
        if not noclipConnection then
            noclipConnection = RunService.Stepped:Connect(function()
                local character = player.Character
                if character then
                    for _, part in pairs(character:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
    end
end

-- ================= SISTEMA DE VOO DOS DEUSES (TWEEN FLYING) ================= --
local function voarAteAlvo(destinoCFrame, velocidade)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    ativarNoclipLocal(true)

    if _G.BypassWalls then
        -- Sobe para o céu
        local posSubida = CFrame.new(rootPart.Position.X, _G.AlturaSeguraCeu, rootPart.Position.Z)
        local t1 = TweenService:Create(rootPart, TweenInfo.new((rootPart.Position - posSubida.Position).Magnitude / velocidade, Enum.EasingStyle.Linear), {CFrame = posSubida})
        t1:Play() t1.Completed:Wait()

        -- Alinha sobre o alvo
        local posCeuAlvo = CFrame.new(destinoCFrame.Position.X, _G.AlturaSeguraCeu, destinoCFrame.Position.Z)
        local t2 = TweenService:Create(rootPart, TweenInfo.new((rootPart.Position - posCeuAlvo.Position).Magnitude / velocidade, Enum.EasingStyle.Linear), {CFrame = posCeuAlvo})
        t2:Play() t2.Completed:Wait()

        -- Desce no alvo
        local t3 = TweenService:Create(rootPart, TweenInfo.new((rootPart.Position - destinoCFrame.Position).Magnitude / velocidade, Enum.EasingStyle.Linear), {CFrame = destinoCFrame})
        t3:Play() t3.Completed:Wait()
        
    else
        -- Voo Rasante Otimizado
        local posicaoVooRasante = CFrame.new(destinoCFrame.Position.X, destinoCFrame.Position.Y + _G.AlturaHover - 5, destinoCFrame.Position.Z)
        local dist = (rootPart.Position - posicaoVooRasante.Position).Magnitude
        
        local t = TweenService:Create(rootPart, TweenInfo.new(dist / velocidade, Enum.EasingStyle.Linear), {CFrame = posicaoVooRasante})
        t:Play()
        t.Completed:Wait()
    end

    ativarNoclipLocal(false)
end

-- ================= FUNÇÃO DE BUSCA DE ALVOS (COM FILTRO DE COR) ================= --
local function pegarAlvoMaisProximo(nomePasta, nomeItem, corObrigatoria)
    local pasta = Workspace:FindFirstChild(nomePasta)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")

    if pasta and rootPart then
        local alvo = nil
        local menorDistancia = math.huge

        for _, item in pairs(pasta:GetChildren()) do
            if item.Name == nomeItem then
                local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                
                if targetPart then
                    local corValida = true
                    
                    -- Se passamos uma cor específica para buscar, ele verifica se bate
                    if corObrigatoria then
                        -- Checando pela cor RGB [255, 215, 0] ou BrickColor "Deep orange" que está nas suas prints
                        local r, g, b = math.floor(targetPart.Color.R * 255), math.floor(targetPart.Color.G * 255), math.floor(targetPart.Color.B * 255)
                        if (r ~= 255 or g ~= 215 or b ~= 0) and targetPart.BrickColor.Name ~= "Deep orange" then
                            corValida = false
                        end
                    end

                    if corValida then
                        local dist = (rootPart.Position - targetPart.Position).Magnitude
                        if dist < menorDistancia then
                            menorDistancia = dist
                            alvo = targetPart
                        end
                    end
                end
            end
        end
        return alvo
    end
    return nil
end

-- ================= LOOP DO FLY FARM ================= --
task.spawn(function()
    while true do
        local alvoAtual = nil
        
        -- Hierarquia de prioridade do Auto Farm
        if _G.AutoFarmGoldenBerry then
            -- Busca especificamente pela Berry com a cor de dinheiro
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry", true)
        elseif _G.AutoFarmAlien then
            alvoAtual = pegarAlvoMaisProximo("Aliens", "Alien")
        elseif _G.AutoFarmBerry then
            -- Busca qualquer Berry normal
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry")
        end

        if alvoAtual then
            voarAteAlvo(alvoAtual.CFrame, _G.VelocidadeFarm)
            task.wait(0.02)
        end
        
        task.wait(0.1)
    end
end)

-- ================= LOOP DO VOO MANUAL ================= --
local bodyVelocity = nil
local bodyGyro = nil

RunService.RenderStepped:Connect(function()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    local camera = Workspace.CurrentCamera

    if _G.VooLivreAtivo and rootPart and humanoid and camera then
        if not bodyVelocity or bodyVelocity.Parent ~= rootPart then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Parent = rootPart
        end
        
        if not bodyGyro or bodyGyro.Parent ~= rootPart then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.D = 100
            bodyGyro.P = 10000
            bodyGyro.Parent = rootPart
        end

        bodyGyro.CFrame = camera.CFrame

        local direcao = humanoid.MoveDirection
        if direcao.Magnitude > 0 then
            bodyVelocity.Velocity = direcao * _G.VelocidadeVoo
        else
            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    else
        if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
    end
end)

