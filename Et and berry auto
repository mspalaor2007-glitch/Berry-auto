-- ================= VARIÁVEIS GLOBAIS DE CONTROLE ================= --
_G.AutoFarmGoldenBerry = false
_G.AutoFarmBerry = false
_G.AutoFarmAlien = false
_G.VelocidadeFarm = 33
_G.BypassWalls = false
_G.AlturaHover = 6
_G.AlturaSeguraCeu = 110

_G.VooLivreAtivo = false
_G.VelocidadeVoo = 33

_G.PerseguirPlayer = false
_G.PlayerAlvo = ""
_G.ModoAleatorioPlayers = false
_G.DistanciaCostas = 4
_G.VelocidadePerseguicao = 35

local function checarAutomacaoAtiva()
    return _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry or _G.PerseguirPlayer
end

-- ================= FUNÇÃO SISTÊMICA: NOCLIP ================= --
local noclipConnection = nil
local function ativarNoclipLocal(status)
    if status then
        if not noclipConnection then
            noclipConnection = RunService.Stepped:Connect(function()
                local character = player.Character
                if character then
                    for _, part in pairs(character:GetChildren()) do
                        if part:IsA("BasePart") then 
                            part.CanCollide = false 
                        end
                    end
                end
            end)
        end
    else
        if noclipConnection then 
            noclipConnection:Disconnect() 
            noclipConnection = nil 
        end
    end
end

-- ================= NOVO MOTOR DE VOO: CFRAME SUAVE (INQUEBRÁVEL) ================= --
local function voarAteAlvoSeparado(alvo, velocidade)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    if not rootPart or not humanoid or not alvo or not alvo.Parent then return end
    
    ativarNoclipLocal(true)
    
    -- Zera as forças físicas para evitar conflitos estarem travando o boneco
    rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0,0,0)
    
    local alturaAlvo = alvo.Position.Y + _G.AlturaHover - 5
    if _G.BypassWalls then 
        alturaAlvo = _G.AlturaSeguraCeu 
    end
    
    while _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry do
        if not alvo or not alvo.Parent or not rootPart then break end
        
        -- Posição final desejada (X, Altura corrigida, Z)
        local destinoFinal = Vector3.new(alvo.Position.X, alturaAlvo, alvo.Position.Z)
        local direcao = (destinoFinal - rootPart.Position)
        local distancia = direcao.Magnitude
        
        if distancia < 1.5 then break end
        
        -- Move via CFrame (Calculado por tempo/frames para ser idêntico a uma velocidade real)
        local passo = direcao.Unit * (velocidade * 0.02)
        if passo.Magnitude > distancia then
            passo = direcao
        end
        
        rootPart.CFrame = CFrame.lookAt(rootPart.Position + passo, Vector3.new(alvo.Position.X, rootPart.Position.Y, alvo.Position.Z))
        
        task.wait(0.02)
    end
    
    ativarNoclipLocal(false)
end

-- ================= MOTOR DE VOO: MANUAL ================= --
local bodyVelocity, bodyGyro = nil, nil
RunService.RenderStepped:Connect(function()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    local camera = Workspace.CurrentCamera
    
    if _G.VooLivreAtivo and not checarAutomacaoAtiva() and rootPart and humanoid and camera then
        ativarNoclipLocal(true)
        humanoid.PlatformStand = true
        
        if not bodyVelocity or bodyVelocity.Parent ~= rootPart then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Parent = rootPart
        end
        if not bodyGyro or bodyGyro.Parent ~= rootPart then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.D = 100
            bodyGyro.P = 10000
            bodyGyro.Parent = rootPart
        end
        
        bodyGyro.CFrame = camera.CFrame
        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)
        
        local dir = humanoid.MoveDirection
        if dir.Magnitude > 0 then
            local vetorCamera = camera.CFrame.LookVector
            local direcaoVoo = Vector3.new(dir.X, vetorCamera.Y, dir.Z)
            bodyVelocity.Velocity = direcaoVoo.Unit * _G.VelocidadeVoo
        else
            bodyVelocity.Velocity = Vector3.new(0,0,0)
        end
    else
        if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        if humanoid and humanoid.PlatformStand and not checarAutomacaoAtiva() then
            humanoid.PlatformStand = false
        end
    end
end)
-- ================= FUNÇÃO DE BUSCA DE ALVOS (FARM) ================= --
local function pegarAlvoMaisProximo(nomePasta, nomeItem, corObrigatoria)
    local pasta = Workspace:FindFirstChild(nomePasta)
    local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    
    if pasta and rootPart then
        local alvo, menorDistancia = nil, math.huge
        for _, item in pairs(pasta:GetChildren()) do
            if item.Name == nomeItem then
                local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                if targetPart then
                    local colValida = true
                    if corObrigatoria and targetPart.BrickColor.Name ~= "Deep orange" then 
                        colValida = false 
                    end
                    if colValida then
                        local dist = (rootPart.Position - targetPart.Position).Magnitude
                        if dist < menorDistancia then 
                            menorDistancia = dist
                            alvo = targetPart 
                        end
                    end
                end
            end
        end
        return alvo
    end
    return nil
end

-- Loop Principal do Fly Farm
task.spawn(function()
    while true do
        local alvoAtual = nil
        if _G.AutoFarmGoldenBerry then 
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry", true)
        elseif _G.AutoFarmAlien then 
            alvoAtual = pegarAlvoMaisProximo("Aliens", "Alien")
        elseif _G.AutoFarmBerry then 
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry") 
        end
        
        if alvoAtual then 
            voarAteAlvoSeparado(alvoAtual, _G.VelocidadeFarm) 
        end
        task.wait(0.1)
    end
end)

-- ================= MOTOR DE PERSEGUIÇÃO DE PLAYERS (MÉTODO CFRAME) ================= --
local function obterListaPlayers()
    local lista = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then 
            table.insert(lista, p.Name) 
        end
    end
    return lista
end

task.spawn(function()
    while true do
        if _G.PerseguirPlayer then
            local tPlayer = Players:FindFirstChild(_G.PlayerAlvo)
            
            -- Inteligência de busca por players vivos
            if _G.ModoAleatorioPlayers or not tPlayer or not tPlayer.Character or not tPlayer.Character:FindFirstChild("Humanoid") or tPlayer.Character.Humanoid.Health <= 0 then
                local vivos = {}
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character.Humanoid.Health > 0 then
                        table.insert(vivos, p)
                    end
                end
                if #vivos > 0 then
                    local escolhido = vivos[math.random(1, #vivos)]
                    _G.PlayerAlvo = escolhido.Name
                    tPlayer = escolhido
                end
            end

            -- Perseguição implacável por CFrame Livre de Trava Física
            if tPlayer and tPlayer.Character and tPlayer.Character:FindFirstChild("HumanoidRootPart") then
                local tRoot = tPlayer.Character.HumanoidRootPart
                local rootPart = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")

                if rootPart and humanoid then
                    ativarNoclipLocal(true)
                    
                    -- Zera forças para garantir que nada puxe o boneco para trás
                    rootPart.AssemblyLinearVelocity = Vector3.new(0,0,0)
                    rootPart.AssemblyAngularVelocity = Vector3.new(0,0,0)

                    -- Define a coordenada exata atrás do alvo
                    local posicaoAlvo = (tRoot.CFrame * CFrame.new(0, 0, _G.DistanciaCostas)).Position
                    local direcao = (posicaoAlvo - rootPart.Position)
                    local distancia = direcao.Magnitude

                    if distancia > 0.5 then
                        -- Avança um passo calculado em CFrame na taxa de atualização
                        local passo = direcao.Unit * (_G.VelocidadePerseguicao * 0.02)
                        if passo.Magnitude > distancia then
                            passo = direcao
                        end
                        rootPart.CFrame = CFrame.lookAt(rootPart.Position + passo, tRoot.Position)
                    else
                        -- Trava perfeitamente na nuca se já estiver muito perto
                        rootPart.CFrame = CFrame.new(posicaoAlvo, tRoot.Position)
                    end
                end
            end
        else
            -- Restaura o estado ao desligar o botão
            local humanoid = player.Character and player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.PlatformStand and not _G.VooLivreAtivo then
                humanoid.PlatformStand = false
                ativarNoclipLocal(false)
            end
        end
        task.wait(0.02)
    end
end)

