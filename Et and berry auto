-- ================= PARTE 1: INICIALIZAÇÃO E BUSCADOR POR ATRIBUTOS ================= --
local Players = game:GetService("Players")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")

local player = Players.LocalPlayer

-- Inicialização das Variáveis Globais de Controle (_G)
_G.AutoFarmMegaBerry = _G.AutoFarmMegaBerry or false
_G.AutoFarmGoldenBerry = _G.AutoFarmGoldenBerry or false
_G.AutoFarmAlien = _G.AutoFarmAlien or false
_G.AutoFarmBerry = _G.AutoFarmBerry or false

_G.KillAuraAtivo = _G.KillAuraAtivo or false
_G.PerseguirPlayer = _G.PerseguirPlayer or false
_G.TargetAleatorio = _G.TargetAleatorio or false -- Novo modo aleatório
_G.PlayerAlvo = _G.PlayerAlvo or ""
_G.DistanciaCostas = _G.DistanciaCostas or 4
_G.VelocidadePerseguicao = _G.VelocidadePerseguicao or 35

local function obterBerryPorAtributo(tipoFarm)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end

    local menorDistancia = math.huge
    local itemEscolhido = nil
    
    for _, objeto in pairs(Workspace:GetDescendants()) do
        if objeto.Name == "Berry" and objeto:IsA("BasePart") then
            local valorAtributo = objeto:GetAttribute("BerryType")
            local valido = false
            
            if tipoFarm == "Mega" and valorAtributo and (string.find(string.lower(valorAtributo), "mega") or string.find(string.lower(valorAtributo), "super")) then
                valido = true
            elseif tipoFarm == "Golden" and valorAtributo and (string.lower(valorAtributo) == "gold" or string.lower(valorAtributo) == "golden") then
                valido = true
            elseif tipoFarm == "Alien" and valorAtributo and string.lower(valorAtributo) == "alien" then
                valido = true
            elseif tipoFarm == "Comum" and valorAtributo and string.lower(valorAtributo) == "normal" then
                valido = true
            end

            if valido and objeto.Position then
                local distancia = (rootPart.Position - objeto.Position).Magnitude
                if distancia < menorDistancia then
                    menorDistancia = distancia
                    itemEscolhido = objeto
                end
            end
        end
    end
    return itemEscolhido
end

print("[INFO] Parte 1 Carregada.")
-- ================= PARTE 2: LOOP DE TELEPORTE E MOTOR PVP ALEATÓRIO ================= --
local flyStateEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("FlyStateChanged")

-- Loop das Berries (Mantido fix de movimento)
RunService.Heartbeat:Connect(function()
    local farmAtivo = _G.AutoFarmMegaBerry or _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    
    if not farmAtivo then
        if humanoid and humanoid.PlatformStand and not _G.PerseguirPlayer then
            humanoid.PlatformStand = false
        end
        return 
    end

    if not rootPart or not humanoid then return end

    humanoid.PlatformStand = true
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

    local alvoAtual = nil
    if _G.AutoFarmMegaBerry then alvoAtual = obterBerryPorAtributo("Mega")
    elseif _G.AutoFarmGoldenBerry then alvoAtual = obterBerryPorAtributo("Golden")
    elseif _G.AutoFarmAlien then alvoAtual = obterBerryPorAtributo("Alien")
    elseif _G.AutoFarmBerry then alvoAtual = obterBerryPorAtributo("Comum") end

    if alvoAtual and alvoAtual.Position then
        rootPart.CFrame = CFrame.new(alvoAtual.Position)
    end
end)

-- Sistema de Perseguição PvP com Seleção Aleatória Dinâmica
local attackEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("AttackRequest")

local function selecionarPlayerAleatorio()
    local todosPlayers = Players:GetPlayers()
    local candidatos = {}
    
    for _, p in pairs(todosPlayers) do
        if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local hum = p.Character:FindFirstChildWhichIsA("Humanoid")
            if hum and hum.Health > 0 then
                table.insert(candidatos, p)
            end
        end
    end
    
    if #candidatos > 0 then
        local sorteado = candidatos[math.random(1, #candidatos)]
        return sorteado.Name
    end
    return ""
end

task.spawn(function()
    while true do
        if _G.PerseguirPlayer then
            -- Se o modo aleatório estiver ligado e não houver alvo válido, escolhe um novo
            if _G.TargetAleatorio then
                local playerAtual = Players:FindFirstChild(_G.PlayerAlvo)
                local precisaTrocar = false
                
                if not playerAtual or not playerAtual.Character or not playerAtual.Character:FindFirstChild("HumanoidRootPart") then
                    precisaTrocar = true
                else
                    local hum = playerAtual.Character:FindFirstChildWhichIsA("Humanoid")
                    if not hum or hum.Health <= 0 then
                        precisaTrocar = true
                    end
                end
                
                if precisaTrocar or _G.PlayerAlvo == "" then
                    _G.PlayerAlvo = selecionarPlayerAleatorio()
                    task.wait(0.5) -- Pequena pausa para estabilizar a troca de alvo
                end
            end

            local tPlayer = Players:FindFirstChild(_G.PlayerAlvo)
            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")

            if tPlayer and tPlayer.Character and rootPart and humanoid then
                local tRoot = tPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tHumanoid = tPlayer.Character:FindFirstChildWhichIsA("Humanoid")

                if tRoot and tHumanoid and tHumanoid.Health > 0 then
                    humanoid.PlatformStand = true
                    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                    
                    local posicaoCostas = (tRoot.CFrame * CFrame.new(0, 0, _G.DistanciaCostas)).Position
                    rootPart.CFrame = CFrame.new(posicaoCostas, tRoot.Position)
                    
                    if _G.KillAuraAtivo and attackEvent then
                        attackEvent:FireServer()
                    end
                end
            end
        else
            local character = player.Character
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and not (_G.AutoFarmMegaBerry or _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry) then
                humanoid.PlatformStand = false
            end
        end
        RunService.Heartbeat:Wait()
    end
end)

