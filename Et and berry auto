local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()
local Workspace = game:GetService("Workspace")
local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local RunService = game:GetService("RunService")
local player = Players.LocalPlayer

local Window = Rayfield:CreateWindow({
   Name = "Berry Hitbox & Magnet v5 🍓🧲",
   LoadingTitle = "Modificando Estrutura das Berries...",
   LoadingSubtitle = "Hitbox Expandida + Ímã Ativo",
   ConfigurationSaving = { Enabled = false },
   KeySystem = false
})

local FarmTab = Window:CreateTab("🍓 Funções Fantasma", 4483362458)

-- Variáveis de controle
_G.ImaDeBerry = false
_G.HitboxGigante = false
_G.VelocidadeImaBerry = 40

-- Tabela para guardar o tamanho original das frutas e restaurar se desligar
local tamanhosOriginais = {}

-- ================= LOOP 1: ÍMÃ DESLIZANTE DE BERRIES ================= --
task.spawn(function()
    while true do
        if _G.ImaDeBerry then
            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local berriesFolder = Workspace:FindFirstChild("Berries")
            
            if rootPart and berriesFolder then
                pcall(function()
                    for _, berry in pairs(berriesFolder:GetChildren()) do
                        if berry:IsA("BasePart") and berry.Name == "Berry" and not berry:GetAttribute("SendoPuxado") then
                            
                            berry:SetAttribute("SendoPuxado", true)
                            berry.Anchored = true
                            berry.CanCollide = false
                            
                            task.spawn(function()
                                while berry and berry.Parent and _G.ImaDeBerry do
                                    local playerPos = rootPart.Position
                                    local dist = (playerPos - berry.Position).Magnitude
                                    
                                    if dist < 3 then
                                        berry.Anchored = false
                                        -- Força o toque físico caso o firetouchinterest seja necessário
                                        firetouchinterest(rootPart, berry, 0)
                                        task.wait()
                                        firetouchinterest(rootPart, berry, 1)
                                        break
                                    end
                                    
                                    local tempo = dist / _G.VelocidadeImaBerry
                                    local tween = TweenService:Create(berry, TweenInfo.new(tempo, Enum.EasingStyle.Linear), {CFrame = CFrame.new(playerPos)})
                                    tween:Play()
                                    
                                    task.wait(0.1)
                                end
                            end)
                        end
                    end
                end)
            end
        end
        task.wait(0.3)
    end
end)

-- ================= LOOP 2: EXPANSÃO DE HITBOX + TOUCH INTEREST ================= --
task.spawn(function()
    while true do
        local berriesFolder = Workspace:FindFirstChild("Berries")
        local character = player.Character
        local rootPart = character and character:FindFirstChild("HumanoidRootPart")

        if berriesFolder then
            pcall(function()
                for _, berry in pairs(berriesFolder:GetChildren()) do
                    if berry:IsA("BasePart") and berry.Name == "Berry" then
                        
                        -- Salva o tamanho original para não perder o controle
                        if not tamanhosOriginais[berry] then
                            tamanhosOriginais[berry] = berry.Size
                        end

                        if _G.HitboxGigante then
                            -- Deixa a fruta ENORME (Hitbox Invisível de 15x15x15 studs)
                            berry.Size = Vector3.new(15, 15, 15)
                            berry.Transparency = 0.7 -- Fica semi-transparente para você ver o tamanho do raio
                            berry.CanCollide = false
                            
                            -- Se você estiver por perto, o Toque Fantasma suga ela instantly
                            if rootPart then
                                local distancia = (rootPart.Position - berry.Position).Magnitude
                                if distancia < 20 then
                                    firetouchinterest(rootPart, berry, 0)
                                    task.wait()
                                    firetouchinterest(rootPart, berry, 1)
                                end
                            end
                        else
                            -- Se desligar o botão, volta ao tamanho normal de fábrica
                            if tamanhosOriginais[berry] then
                                berry.Size = tamanhosOriginais[berry]
                                berry.Transparency = 0
                            end
                        end
                    end
                end
            end)
        end
        task.wait(0.5)
    end
end)

-- ================= INTERFACE GRÁFICA ================= --

FarmTab:CreateSection("🧲 MODO ÍMÃ (TRAZ A FRUTA ATÉ VOCÊ)")

FarmTab:CreateToggle({
   Name = "Ativar Ímã de Berries (Deslizar)",
   CurrentValue = false,
   Callback = function(Value)
       _G.ImaDeBerry = Value
   end,
})

FarmTab:CreateSlider({
   Name = "Velocidade do Ímã",
   Range = {20, 100},
   Increment = 5,
   Suffix = "Vel",
   CurrentValue = 40,
   Callback = function(Value)
       _G.VelocidadeImaBerry = Value
   end,
})

FarmTab:CreateSection("⚡ MODO HITBOX GIGANTE (AUMENTAR FRUTA)")

FarmTab:CreateToggle({
   Name = "Expandir Hitbox das Berries (15 Studs)",
   CurrentValue = false,
   Callback = function(Value)
       _G.HitboxGigante = Value
   end,
})
