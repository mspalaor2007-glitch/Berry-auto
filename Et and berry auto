-- ================= NOCLIP LOCAL PARA EVITAR COLISÕES ================= --
local noclipConnection = nil
local function ativarNoclipLocal(status)
    if status then
        if not noclipConnection then
            noclipConnection = RunService.Stepped:Connect(function()
                local character = player.Character
                if character then
                    for _, part in pairs(character:GetChildren()) do
                        if part:IsA("BasePart") then
                            part.CanCollide = false
                        end
                    end
                end
            end)
        end
    else
        if noclipConnection then
            noclipConnection:Disconnect()
            noclipConnection = nil
        end
    end
end

-- ================= MOVIMENTAÇÃO DINÂMICA: FÍSICA HORIZONTAL + CFRAME VERTICAL ================= --
local function voarAteAlvoSeparado(alvo, velHorizontal, velVertical)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    if not rootPart or not humanoid or not alvo or not alvo.Parent then return end

    ativarNoclipLocal(true)
    humanoid.PlatformStand = true 

    local alturaAlvo = alvo.Position.Y + _G.AlturaHover - 5
    if _G.BypassWalls then
        alturaAlvo = _G.AlturaSeguraCeu
    end

    while _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry do
        if not alvo or not alvo.Parent or not rootPart then break end

        -- 1️⃣ CONTROLE VERTICAL (CFrame para Subir sem Engasgar)
        local alturaAtual = rootPart.Position.Y
        local diferencaY = alturaAlvo - alturaAtual
        
        if math.abs(diferencaY) > 0.3 then
            local direcaoY = diferencaY > 0 and 1 or -1
            local passoY = direcaoY * velVertical * 0.02 
            if math.abs(passoY) > math.abs(diferencaY) then
                alturaAtual = alturaAlvo
            else
                alturaAtual = alturaAtual + passoY
            end
            rootPart.CFrame = CFrame.new(rootPart.Position.X, alturaAtual, rootPart.Position.Z) * rootPart.CFrame.Rotation
        end

        -- 2️⃣ CONTROLE HORIZONTAL (Física de Velocidade no Plano)
        local destinoHorizontal = Vector3.new(alvo.Position.X, rootPart.Position.Y, alvo.Position.Z)
        local direcaoHorizontal = (destinoHorizontal - rootPart.Position)
        local distHorizontal = direcaoHorizontal.Magnitude

        if distHorizontal < 1.5 and math.abs(rootPart.Position.Y - alturaAlvo) < 1.5 then 
            break 
        end

        if distHorizontal > 0.5 then
            local olharSeguro = Vector3.new(alvo.Position.X, rootPart.Position.Y, alvo.Position.Z)
            rootPart.CFrame = CFrame.lookAt(rootPart.Position, olharSeguro)
        end

        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

        if distHorizontal > 0.1 then
            local direcaoUnit = direcaoHorizontal.Unit
            rootPart.AssemblyLinearVelocity = Vector3.new(direcaoUnit.X * velHorizontal, 0, direcaoUnit.Z * velHorizontal)
        else
            rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end

        task.wait(0.02)
    end

    if rootPart then rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0) end
    if humanoid then humanoid.PlatformStand = false end
    ativarNoclipLocal(false)
end

-- ================= FUNÇÃO DE BUSCA DE ALVOS ================= --
local function pegarAlvoMaisProximo(nomePasta, nomeItem, corObrigatoria)
    local pasta = Workspace:FindFirstChild(nomePasta)
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")

    if pasta and rootPart then
        local alvo = nil
        local menorDistancia = math.huge

        for _, item in pairs(pasta:GetChildren()) do
            if item.Name == nomeItem then
                local targetPart = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                
                if targetPart then
                    local colValida = true
                    if corObrigatoria and targetPart.BrickColor.Name ~= "Deep orange" then
                        colValida = false
                    end

                    if colValida then
                        local dist = (rootPart.Position - targetPart.Position).Magnitude
                        if dist < menorDistancia then
                            menorDistancia = dist
                            alvo = targetPart
                        end
                    end
                end
            end
        end
        return alvo
    end
    return nil
end

-- ================= LOOP DO FLY FARM ================= --
task.spawn(function()
    while true do
        local alvoAtual = nil
        
        if _G.AutoFarmGoldenBerry then
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry", true)
        elseif _G.AutoFarmAlien then
            alvoAtual = pegarAlvoMaisProximo("Aliens", "Alien")
        elseif _G.AutoFarmBerry then
            alvoAtual = pegarAlvoMaisProximo("Berries", "Berry")
        end

        if alvoAtual then
            voarAteAlvoSeparado(alvoAtual, _G.VelocidadeFarm, _G.VelocidadeSubidaCFrame)
        end
        
        task.wait(0.1)
    end
end)

-- ================= MOTOR DE VOO MANUAL (BODYVELOCITY) ================= --
local bodyVelocity = nil
local bodyGyro = nil

RunService.RenderStepped:Connect(function()
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    local camera = Workspace.CurrentCamera

    if _G.VooLivreAtivo and rootPart and humanoid and camera then
        ativarNoclipLocal(true)
        humanoid.PlatformStand = true

        if not bodyVelocity or bodyVelocity.Parent ~= rootPart then
            bodyVelocity = Instance.new("BodyVelocity")
            bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bodyVelocity.Parent = rootPart
        end
        
        if not bodyGyro or bodyGyro.Parent ~= rootPart then
            bodyGyro = Instance.new("BodyGyro")
            bodyGyro.MaxTorque = Vector3.new(math.huge, math.huge, math.huge)
            bodyGyro.D = 100
            bodyGyro.P = 10000
            bodyGyro.Parent = rootPart
        end

        bodyGyro.CFrame = camera.CFrame

        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

        local direcao = humanoid.MoveDirection
        if direcao.Magnitude > 0 then
            local vetorCamera = camera.CFrame.LookVector
            local direcaoVoo = Vector3.new(direcao.X, vetorCamera.Y, direcao.Z)
            
            bodyVelocity.Velocity = direcaoVoo.Unit * _G.VelocidadeVoo
        else
            bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        end
    else
        if bodyVelocity then bodyVelocity:Destroy() bodyVelocity = nil end
        if bodyGyro then bodyGyro:Destroy() bodyGyro = nil end
        
        if humanoid and humanoid.PlatformStand and not _G.PerseguirPlayer then
            humanoid.PlatformStand = false
            ativarNoclipLocal(false)
        end
    end
end)

-- ================= SISTEMA DE PERSEGUIÇÃO DE PLAYERS (VIVOS) ================= --
local function obterListaPlayers()
    local lista = {}
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= player then
            table.insert(lista, p.Name)
        end
    end
    return lista
end

task.spawn(function()
    while true do
        if _G.PerseguirPlayer then
            local tPlayer = Players:FindFirstChild(_G.PlayerAlvo)
            
            if _G.ModoAleatorioPlayers or not tPlayer or not tPlayer.Character or not tPlayer.Character:FindFirstChild("Humanoid") or tPlayer.Character.Humanoid.Health <= 0 then
                local todosPlayers = {}
                for _, p in pairs(Players:GetPlayers()) do
                    if p ~= player and p.Character and p.Character:FindFirstChild("Humanoid") and p.Character.Humanoid.Health > 0 then
                        table.insert(todosPlayers, p)
                    end
                end
                
                if #todosPlayers > 0 then
                    local escolhido = todosPlayers[math.random(1, #todosPlayers)]
                    if _G.ModoAleatorioPlayers or _G.PlayerAlvo == "" then
                        _G.PlayerAlvo = escolhido.Name
                        tPlayer = escolhido
                    end
                end
            end

            local character = player.Character
            local rootPart = character and character:FindFirstChild("HumanoidRootPart")
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")

            if tPlayer and tPlayer.Character and rootPart and humanoid then
                local tRoot = tPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tHumanoid = tPlayer.Character:FindFirstChild("Humanoid")

                if tRoot and tHumanoid and tHumanoid.Health > 0 then
                    ativarNoclipLocal(true)
                    humanoid.PlatformStand = true

                    local posicaoCostas = (tRoot.CFrame * CFrame.new(0, 0, _G.DistanciaCostas)).Position
                    local direcaoIr = (posicaoCostas - rootPart.Position)
                    local distanciaAtual = direcaoIr.Magnitude

                    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

                    if distanciaAtual > 0.5 then
                        rootPart.AssemblyLinearVelocity = direcaoIr.Unit * _G.VelocidadePerseguicao
                        rootPart.CFrame = CFrame.lookAt(rootPart.Position, Vector3.new(tRoot.Position.X, rootPart.Position.Y, tRoot.Position.Z))
                    else
                        rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
                        rootPart.CFrame = CFrame.new(posicaoCostas, tRoot.Position)
                    end
                end
            end
        else
            local character = player.Character
            local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
            if humanoid and humanoid.PlatformStand and not _G.VooLivreAtivo then
                humanoid.PlatformStand = false
                ativarNoclipLocal(false)
            end
        end
        task.wait(0.02)
    end
end)

