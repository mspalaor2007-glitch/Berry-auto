-- ================= PARTE 2: LOOPS, MOTOR DE VOO E AUTO ATTACK ================= --
local flyStateEvent = ReplicatedStorage:WaitForChild("Events"):WaitForChild("FlyStateChanged")
local attackEvent = ReplicatedStorage:WaitForChild("Events"):FindFirstChild("AttackRequest")

-- Loop de Atualização do Voo (Força o atributo IsFlyingMorph no Personagem)
RunService.Heartbeat:Connect(function()
    local character = player.Character
    if character then
        -- Compara o estado atual do atributo com o Toggle da UI para evitar spam desnecessário
        if character:GetAttribute("IsFlyingMorph") ~= _G.FlyMorphAtivo then
            character:SetAttribute("IsFlyingMorph", _G.FlyMorphAtivo)
        end
    end
end)

-- Loop Automático das Berries (Mantém o fix de física e movimento travado)
RunService.Heartbeat:Connect(function()
    local farmAtivo = _G.AutoFarmMegaBerry or _G.AutoFarmGoldenBerry or _G.AutoFarmAlien or _G.AutoFarmBerry
    local character = player.Character
    local rootPart = character and character:FindFirstChild("HumanoidRootPart")
    local humanoid = character and character:FindFirstChildWhichIsA("Humanoid")
    
    if not farmAtivo then
        -- Se o farm desligar e não estiver caçando player, devolve o controle do boneco
        if humanoid and humanoid.PlatformStand and not _G.PerseguirPlayer then
            humanoid.PlatformStand = false
        end
        return 
    end

    if not rootPart or not humanoid then return end

    -- Trava a física do personagem para não bugar no teletransporte
    humanoid.PlatformStand = true
    rootPart.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
    rootPart.AssemblyAngularVelocity = Vector3.new(0, 0, 0)

    local alvoAtual = nil
    if _G.AutoFarmMegaBerry then alvoAtual = obterBerryPorAtributo("Mega")
    elseif _G.AutoFarmGoldenBerry then alvoAtual = obterBerryPorAtributo("Golden")
    elseif _G.AutoFarmAlien then alvoAtual = obterBerryPorAtributo("Alien")
    elseif _G.AutoFarmBerry then alvoAtual = obterBerryPorAtributo("Comum") end

    if alvoAtual and alvoAtual.Position then
        rootPart.CFrame = CFrame.new(alvoAtual.Position)
    end
end)

-- Loop Isolado de Auto Attack / Kill Aura Avançado (Roda em segundo plano)
task.spawn(function()
